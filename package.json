{
  "name": "virtualpianopedia",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "description": "Roblox virtual piano sheets with variants, favorites, and MIDI conversion",
  "homepage": "https://jasperdevs.github.io/VirtualPianoPedia/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasperdevs/VirtualPianoPedia.git"
  },
  "scripts": {
    "dev": "vite",
    "convert:midi": "node scripts/convert-midi.mjs",
    "converter:smoke": "node scripts/smoke-converter.mjs",
    "songs:index": "node scripts/update-readme-songs.mjs",
    "sheets:validate": "node scripts/validate-sheets.mjs",
    "build": "npm run songs:index && npm run sheets:validate && tsc -b && vite build && node -e \"fs.copyFileSync('dist/index.html','dist/404.html')\"",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@tonejs/midi": "^2.0.28",
    "clsx": "^2.1.1",
    "framer-motion": "^12.39.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.10.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.1",
    "vite": "^7.2.7"
  }
}
